;==========BIBLIOTECA DE MACROS=============
;NATIVIDAD AGUILERA ANDRICK JOKSAN
;===========================================

;=========SECCION DE MACROS=========== 

LIMPIAR_PANTALLA MACRO
    MOV AH,00
    MOV AL,03
    INT 10H
LIMPIAR_PANTALLA ENDM

CURSOR MACRO REN,COL,PAG
    MOV AH,2
    MOV DH,REN
    MOV DL,COL
    MOV BH,PAG
    INT 10H
    CURSOR ENDM
;=====================================
IMP_SINCOLOR MACRO CADENA
    MOV AH,9
    LEA DX,CADENA
    INT 21H
    IMP_SINCOLOR ENDM
;=====================================
RASTREO MACRO 
    MOV AH,0
    INT 16H
    RASTREO ENDM


;==========MACRO PARA CARPETAS=============
CREAR_CARPETA MACRO RUTA
    MOV AH,39H
    LEA DX,RUTA 
    INT 21H
CREAR_CARPETA ENDM

;=========MACRO PARA CREAR ARCHIVOS========
CREAR_ARCHIVO MACRO RUTA,TIPO
    ;NOTA: El tipo de archivo 32 es el de USUARIO 
    MOV AH,3CH
    LEA DX,RUTA
    MOV CX,TIPO
    INT 21H
CREAR_ARCHIVO ENDM


ABRIR_ARCHIVO MACRO RUTA,MODO
	;MODO
	;0-SOLO LECTURA
	;1-SOLO ESCRITURA
	;2-LECTURA/ESCRITURA
	MOV AH,3DH
	LEA DX,RUTA
	MOV AL,MODO
	INT 21H
ABRIR_ARCHIVO ENDM

LEER_ARCHIVO MACRO ID,CANTIDAD,LEIDOS
	MOV AH,3FH
	LEA DX,LEIDOS
	MOV CX,CANTIDAD
	MOV BX,ID
	INT 21H
LEER_ARCHIVO ENDM

LECTURA_CADENA MACRO CADENA
	MOV AH,10
	LEA DX,CADENA
	INT 21H
LECTURA_CADENA ENDM

;=====================================
IMP_COLOR MACRO CADENA,LONGITUD,PAGINA,MODO,REN,COL,COLOR
    MOV AH,13H
    MOV AL,MODO
    MOV BH,PAGINA
    MOV BL,COLOR
    MOV CX,LONGITUD
    MOV DH,REN
    MOV DL,COL
    LEA BP,CADENA
    INT 10H
IMP_COLOR ENDM
;=====================================

ESCRIBIR_ARCHIVO MACRO ID,CANTIDAD,DATOS
MOV AH,40H
MOV BX,ID
MOV CX,CANTIDAD
LEA DX,DATOS
INT 21H
ESCRIBIR_ARCHIVO ENDM

;=====================================
MSJ_LCD MACRO CADENA,LONG
    MOV CX,LONG
    MOV SI,0 
    
    MOV DX, 2040H ;PUERTO INICIAL
CICLO:   
    MOV AL,CADENA[SI]
    OUT DX,AL 
    INC SI
    INC DX    
    LOOP CICLO   
MSJ_LCD ENDM

CERRAR_ARCHIVO MACRO HANDLE
    MOV AH,3EH
    MOV BX,HANDLE
    INT 21H
ENDM
;=========FIN DE MACROS===============

;=========MACROS TERMOMETRO===========
ENCENDERTERMOMETRO MACRO
MOV DX,127
MOV AL,1
OUT DX,AL

MOV AH,2
MOV DH,22
MOV DL,25
MOV BH,0
INT 10H
ENCENDERTERMOMETRO ENDM 

APAGARTERMOMETRO MACRO
MOV DX,127
MOV AL,0
OUT DX,AL

MOV AH,2
MOV DH,22
MOV DL,25
MOV BH,0
INT 10H
APAGARTERMOMETRO ENDM


